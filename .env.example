# =============================================================================
# Interview Optimiser - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# Alternatively, use Doppler: doppler setup -c dev -p interview-optimiser
# =============================================================================

# --- App ---
ID_ENCODING_SALT=your-secure-random-salt-here          # openssl rand -base64 32
EMAIL_HASH_SALT=your-secure-email-hash-salt-here       # openssl rand -base64 32
CSRF_SECRET=your-csrf-secret-here                      # openssl rand -base64 32
ADMIN_EMAIL=your-admin-email@example.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/interviewoptimiser

# --- Clerk (Authentication) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# --- Hume AI (Voice Interviews) ---
HUME_API_KEY=...
HUME_SECRET_KEY=...
NEXT_PUBLIC_HUME_CONFIG_ID=...

# --- OpenAI (AI Analysis) ---
OPENAI_API_KEY=sk-...

# --- Stripe (Payments) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SIGNING_SECRET=whsec_...

# --- AWS (Audio Storage) ---
AWS_REGION=eu-west-2
AUDIO_BUCKET_NAME=your-bucket-name
AUDIO_CDN_DOMAIN=your-cdn.cloudfront.net
CLOUDFRONT_KEY_PAIR_ID=...
CLOUDFRONT_PRIVATE_KEY=...

# --- Upstash Redis (Rate Limiting & Caching) ---
KV_REST_API_URL=https://...upstash.io
KV_REST_API_TOKEN=...

# --- Inngest (Background Jobs) ---
# Not required for local dev (uses Inngest Dev Server)
# INNGEST_SIGNING_KEY=signkey-...
# INNGEST_EVENT_KEY=...

# --- Sentry (Error Monitoring) ---
SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=sntrys_...

# --- PostHog (Analytics) ---
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Resend (Email) ---
RESEND_API_KEY=re_...

# --- Discord (Notifications) ---
DISCORD_BOT_TOKEN=...
