# ID Encoding Salt
# CRITICAL: Generate a secure random string for production use
# Example: openssl rand -base64 32
ID_ENCODING_SALT=your-secure-random-salt-here

# Email Hash Salt for tracking deleted users
# CRITICAL: Generate a secure random string for production use
# This salt is used to hash emails of deleted users to prevent free minutes abuse
# Example: openssl rand -base64 32
EMAIL_HASH_SALT=your-secure-email-hash-salt-here

