#!/bin/bash

set -e  # Exit immediately if a command exits with a non-zero status.
set -x  # Print commands and their arguments as they are executed.

trap 'echo "Error: Script failed at line $LINENO"; exit 1;' ERR

rm -rf terraform/artifacts/$1
mkdir -p terraform/artifacts/$1

pnpm install
rm -rf functions/dist/$1

doppler run -c prd -p interview-optimiser -- node -r esbuild-register scripts/build-lambda.ts $1

rm -rf terraform/artifacts/$1
mkdir -p terraform/artifacts/$1

cp -rv functions/dist/$1/* terraform/artifacts/$1/