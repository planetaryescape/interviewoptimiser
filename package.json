{
  "name": "interviewoptimiser",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "env": "doppler setup -c dev -p interview-optimiser",
    "dev": "SENTRY_SUPPRESS_TURBOPACK_WARNING=1 NODE_OPTIONS='--trace-deprecation' doppler run -- next dev --turbopack | pino-pretty",
    "email:build": "email build -d ./src/emails -p bun",
    "email:dev": "email dev",
    "email:export": "email export -d ./src/emails -p bun",
    "build": "next build",
    "build:time": "cross-env TIMING=1 next build",
    "analyze": "cross-env ANALYZE=true next build",
    "build:check": "tsc --noEmit && next build",
    "typecheck": "tsc --noEmit",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "doppler run -- drizzle-kit generate",
    "db:drop": "doppler run -- drizzle-kit drop",
    "db:studio:ci": "drizzle-kit studio",
    "db:studio": "doppler run -- drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:dev": "NODE_ENV=development doppler run -- drizzle-kit migrate",
    "db:migrate:prd": "NODE_ENV=production doppler run -c prd -- drizzle-kit migrate",
    "db:migrate:stg": "NODE_ENV=production doppler run -c stg -- drizzle-kit migrate",
    "tf-build": "./bin/copy-artifacts-to-terraform",
    "tf-apply": "bun tf-build && ./bin/terraform-apply",
    "tf-apply-local": "bun tf-build && ./bin/terraform-apply-local",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "fmt": "biome format . --write",
    "check": "biome check . --write",
    "prepare": "husky"
  },
