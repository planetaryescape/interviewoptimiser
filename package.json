{
  "name": "interviewoptimiser",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "env": "doppler setup -c dev -p interviewoptimiser",
    "dev": "SENTRY_SUPPRESS_TURBOPACK_WARNING=1 doppler run -- next dev --turbopack | pino-pretty",
    "email:build": "email build -d ./src/emails -p pnpm",
    "email:dev": "email dev",
    "email:export": "email export -d ./src/emails -p pnpm",
    "build": "next build",
    "start": "next start",
    "db:generate": "doppler run -- drizzle-kit generate",
    "db:drop": "doppler run -- drizzle-kit drop",
    "db:studio:ci": "drizzle-kit studio",
    "db:studio": "doppler run -- drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:dev": "NODE_ENV=development doppler run -- drizzle-kit migrate",
    "db:migrate:prd": "NODE_ENV=production doppler run -c prd -- drizzle-kit migrate",
    "db:migrate:stg": "NODE_ENV=production doppler run -c stg -- drizzle-kit migrate",
    "terraform:regenerate-incomplete-reports": "bin/build-and-copy-artifacts regenerate-incomplete-reports",
    "terraform:generate-report": "bin/build-and-copy-artifacts generate-report",
    "terraform:restore-database": "./bin/build-and-copy-artifacts restore-database",
    "terraform:vet-review": "bin/build-and-copy-artifacts vet-review",
    "tfa-local": "pnpm terraform:regenerate-incomplete-reports && pnpm terraform:vet-review && pnpm terraform:restore-database && pnpm terraform:generate-report && bin/terraform-apply-local",
    "tfa": "pnpm terraform:regenerate-incomplete-reports && pnpm terraform:vet-review && pnpm terraform:restore-database && pnpm terraform:generate-report && bin/terraform-apply",
    "lint": "oxlint -c .eslintrc.json",
    "lint:fix": "oxlint --fix -c .eslintrc.json",
    "prepare": "husky"
  },
