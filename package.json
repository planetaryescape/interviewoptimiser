{
  "name": "interviewoptimiser",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "env": "doppler setup -c dev -p interviewoptimiser",
    "dev": "doppler run -- next dev | pino-pretty",
    "email:build": "email build -d ./src/emails -p pnpm",
    "email:dev": "email dev",
    "email:export": "email export -d ./src/emails -p pnpm",
    "build": "next build",
    "start": "next start",
    "db:generate": "doppler run -- drizzle-kit generate",
    "db:drop": "doppler run -- drizzle-kit drop",
    "db:studio": "doppler run -- drizzle-kit studio",
    "db:migrate": "NODE_ENV=development doppler run -- drizzle-kit migrate",
    "db:migrate:prd": "NODE_ENV=production doppler run -c prd -- drizzle-kit migrate",
    "db:migrate:stg": "NODE_ENV=production doppler run -c stg -- drizzle-kit migrate",
    "terraform:generate-cover-letter": "bin/build-and-copy-artifacts generate-cover-letter",
    "terraform:optimise-cv": "bin/build-and-copy-artifacts optimise-cv",
    "terraform:add-to-queue": "bin/build-and-copy-artifacts add-to-queue",
    "terraform:restart-incomplete-optimizations": "bin/build-and-copy-artifacts restart-incomplete-optimizations",
    "terraform:generate-pdf": "bin/build-and-copy-artifacts generate-pdf",
    "tfa-local": "pnpm terraform:generate-cover-letter && pnpm terraform:optimise-cv && pnpm terraform:restart-incomplete-optimizations && pnpm terraform:generate-pdf && pnpm terraform:add-to-queue && bin/terraform-apply-local",
    "tfa": "pnpm terraform:generate-cover-letter && pnpm terraform:optimise-cv && pnpm terraform:restart-incomplete-optimizations && pnpm terraform:generate-pdf && pnpm terraform:add-to-queue && bin/terraform-apply",
    "lint": "oxlint -c .eslintrc.json",
    "lint:fix": "oxlint --fix -c .eslintrc.json",
    "prepare": "husky"
  },
